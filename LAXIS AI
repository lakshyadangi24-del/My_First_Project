def now_str():
    return datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")

def get_weather(city=DEFAULT_CITY):
    """Fetch current weather using OpenWeatherMap API"""
    try:
        url = f"http://api.openweathermap.org/data/2.5/weather?q={city}&appid={WEATHER_API_KEY}&units=metric"
        response = requests.get(url)
        data = response.json()
        if data.get("main"):
            temp = data["main"]["temp"]
            desc = data["weather"][0]["description"]
            return f"The weather in {city} is {desc} with {temp}°C."
        else:
            return "Sorry, I couldn't fetch the weather right now."
    except Exception as e:
        logger.exception("Weather fetch failed: %s", e)
        return "Weather service is unavailable."

# ----------------------------
# Chat Client
# ----------------------------
class ChatClient:
    def __init__(self, model_name=MODEL_NAME, system_prompt=None, options=None):
        self.model_name = model_name
        self.system_prompt = system_prompt or "You are LAXIS AI, a friendly intelligent personal assistant."
        self.options = options or {}
        logger.info("ChatClient initialized with model %s", self.model_name)

    def ask(self, user_text):
        try:
            messages = [
                {"role": "system", "content": self.system_prompt},
                {"role": "user", "content": user_text}
            ]
            response = ollama.chat(model=self.model_name, messages=messages, options=self.options)
            content = response.get("message", {}).get("content", "")
            return content
        except Exception as e:
            logger.exception("Error calling Ollama: %s", e)
            return "Sorry, I couldn't reach the AI service right now."

# ----------------------------
# Text-to-Speech
# ----------------------------
class TTS:
    def __init__(self, rate=VOICE_RATE, volume=VOICE_VOLUME, voice_index=VOICE_INDEX):
        self.engine = pyttsx3.init()
        self.engine.setProperty("rate", rate)
        self.engine.setProperty("volume", volume)
        voices = self.engine.getProperty("voices")
        if voices and 0 <= voice_index < len(voices):
            self.engine.setProperty("voice", voices[voice_index].id)
        self.lock = threading.Lock()

    def speak(self, text, block=True):
        if not text:
            return
        with self.lock:
            self.engine.say(text)
            if block:
                self.engine.runAndWait()

    def stop(self):
        with self.lock:
            try:
                self.engine.stop()
            except Exception:
                pass

    def shutdown(self):
        self.stop()
        try:
            del self.engine
        except Exception:
            pass

