    def start(self):
        self.running = True
        self.voice_thread.start()
        self.vision_thread.start()
        self.tts.speak("Hello. I am LAXIS AI. Ready.", block=False)
        self.main_loop()

    def handle_command(self, source, payload):
        if source == "voice":
            self._execute_voice_command(payload)
        elif source == "gesture":
            self._execute_gesture(payload)
        elif source == "system":
            if payload == "exit":
                self.shutdown()

    def _execute_voice_command(self, command):
        if not command:
            return
        if "time" in command:
            now = datetime.datetime.now().strftime("%I:%M %p")
            self.tts.speak("Current time is " + now)
            return
        if "date" in command:
            today = datetime.datetime.now().strftime("%d %B %Y")
            self.tts.speak("Today is " + today)
            return
        if "weather" in command:
            weather_info = get_weather()
            self.tts.speak(weather_info)
            return
        if "open youtube" in command:
            webbrowser.open("https://www.youtube.com")
            self.tts.speak("Opening YouTube")
            return
        if "open chrome" in command or "open google" in command:
            webbrowser.open("https://www.google.com")
            self.tts.speak("Opening Google")
            return
        if "exit" in command or "goodbye" in command or "quit" in command:
            self.tts.speak("Goodbye. Have a nice day.")
            self.shutdown()
            return

        # Otherwise ask AI
        self.tts.speak("Let me think about that.", block=False)
        answer = self.chat.ask(command)
        self.tts.speak(answer)

    def _execute_gesture(self, gesture_name):
        if gesture_name == "pinch":
            status = "I see your pinch gesture. I am ready to take a voice command."
            self.tts.speak(status)

    def main_loop(self):
        while self.running:
            try:
                source, payload = self.command_queue.get(timeout=0.5)
                self.handle_command(source, payload)
            except queue.Empty:
                continue

    def shutdown(self):
        if not self.running:
            return
        self.running = False
        try:
            self.voice_thread.stop()
            self.vision_thread.stop()
        except Exception:
            pass
        time.sleep(0.5)
        try:
            self.tts.shutdown()
        except Exception:
            pass
        sys.exit(0)

